{
  "servers": {
    "sqlMcpServer": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "dab",
        "start",
        "--mcp-stdio",
        "role:anonymous",
        "--LogLevel",
        "Error",
        "--config",
        "${workspaceFolder}/dab-config.json"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DOTNET_ROLL_FORWARD": "Major"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
